#include "{{ header_path }}"
#include <cuda_runtime.h>

#define ITERS 50

int main() {

    DataPointers data;

    cudaStream_t stream1;
    cudaStream_t stream2;
    cudaStreamCreate(&stream1);
    cudaStreamCreate(&stream2);

    setup(&data);

    cudaStreamSynchronize(stream1);
    cudaStreamSynchronize(stream2);

    for (int i = 0; i < ITERS; i++) {
        {% for i in 0..2 -%}
        {% let kernel = config.kernels[i] %}
        {{ kernel.name }}<<<{{ kernel.blocks }}, {{ kernel.threads }}, 0, {{ kernel.stream }}>>>(
            {%- for arg in kernel.args -%}
            data.{% if arg.datatype.ends_with('*') %}d_{% endif %}{{ arg.name }}{% if !loop.last %}, {% endif %}
            {%- endfor -%}
        );
        {% endfor %}
    }

    cudaStreamSynchronize(stream1);
    cudaStreamSynchronize(stream2);

    free_data(&data);

    return 0;
}
